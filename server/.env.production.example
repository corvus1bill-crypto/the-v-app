# Backend Production Environment Variables
# Rename this to .env and fill in the values

# Node environment
NODE_ENV=production

# Server port
PORT=4000

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/thev

# JWT Configuration
JWT_SECRET=your-min-16-character-secure-random-string-here
JWT_EXPIRES_IN=7d

# CORS Configuration
# Use specific domain for production, or comma-separated list of domains
CORS_ORIGIN=https://yourdomain.com

# Force HTTPS redirect for production
FORCE_HTTPS=true

# Trust proxy headers (for deployments behind reverse proxies like Vercel, Railway)
# Set to 0 if not behind proxy, 1 or higher if behind proxy
TRUST_PROXY=1

# Upload directory for temporary file storage
UPLOAD_DIR=/tmp/uploads

# Public base URL for uploaded file access
PUBLIC_BASE_URL=https://api.yourdomain.com

# Optional: Error tracking with Sentry
SENTRY_DSN=

# Optional: Redis URL for caching/sessions
REDIS_URL=

# Optional: Email service (for notifications/verification)
SENDGRID_API_KEY=

# Optional: AWS/S3 Configuration for permanent media storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Optional: Firebase Configuration
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Optional: Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional: Apple OAuth
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
