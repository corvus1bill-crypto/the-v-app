# Frontend Production Environment Variables
# Copy to .env.production and fill in values

# API Configuration
VITE_API_BASE_URL=https://api.yourdomain.com

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Sentry Error Tracking
VITE_SENTRY_DSN=

# Optional: Firebase Analytics
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Mixpanel Analytics
VITE_MIXPANEL_TOKEN=

# Optional: Feature Flags
VITE_ENABLE_VIBES=true
VITE_ENABLE_STORIES=true
VITE_ENABLE_SPOTLIGHT=true
VITE_ENABLE_ANALYTICS=true

# Optional: CDN Configuration
VITE_CDN_URL=https://cdn.yourdomain.com

# Optional: Support/Help Links
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_HELP_URL=https://help.yourdomain.com
